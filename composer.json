{
	"name": "cuny-academic-commons/cboxol-group-invitations",
	"description": "Replaces the BuddyPress group invitation interface with a custom-built one for Commons In A Box OpenLab.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0+",
	"keywords": [
		"wordpress",
		"buddypress",
		"commons-in-a-box",
		"openlab"
	],
	"homepage": "https://github.com/cuny-academic-commons/cboxol-group-invitations",
	"require": {
		"php": ">=8.0"
	},
	"require-dev": {
		"squizlabs/php_codesniffer": "^3.9",
		"wp-coding-standards/wpcs": "^3.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"phpstan/phpstan": "^1.12",
		"phpstan/extension-installer": "^1.4",
		"szepeviktor/phpstan-wordpress": "^1.3",
		"gin0115/buddypress-stubs": "^11.1"
	},
	"autoload": {
		"psr-4": {
			"CBOX\\OL\\GroupInvitations\\": "classes/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"phpstan/extension-installer": true
		}
	},
	"scripts": {
		"phpcs": "phpcs",
		"phpcbf": "phpcbf",
		"phpstan": "phpstan analyse --memory-limit=512M"
	}
}
